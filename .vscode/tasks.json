{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "go",
            "label": "build (linux)",
            "command": "build",
            "args": [
                "-o",
                "bin/gitcc",
                "./cmd/gitcc"
            ],
            "problemMatcher": [
                "$go"
            ],
            "group": "build",
        },
        {
            "type": "go",
            "label": "build (windows)",
            "command": "build",
            "args": [
                "-o",
                "bin/gitcc.exe",
                "./cmd/gitcc"
            ],
            "problemMatcher": [
                "$go"
            ],
            "group": "build",
            "options": {
                "env": {
                    "GOOS": "windows",
                    "GOARCH": "amd64"
                }
            }
        },
        {
            "type": "go",
            "label": "build (macOS Apple Silicon)",
            "command": "build",
            "args": [
                "-o",
                "${workspaceFolder}/dist/gitcc-darwin-arm64",
                "./cmd/gitcc"
            ],
            "problemMatcher": [
                "$go"
            ],
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}/cli",
                "env": {
                    "GOOS": "darwin",
                    "GOARCH": "arm64"
                }
            }
        },
        {
            "type": "go",
            "label": "build (macOS Intel)",
            "command": "build",
            "args": [
                "-o",
                "${workspaceFolder}/dist/gitcc-darwin-amd64",
                "./cmd/gitcc"
            ],
            "problemMatcher": [
                "$go"
            ],
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}/cli",
                "env": {
                    "GOOS": "darwin",
                    "GOARCH": "amd64"
                }
            }
        }
    ]
}